---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TopicCloud from '../components/TopicCloud.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');

// Separate index posts from regular posts
const indexPosts = allPosts.filter(p => p.data.isIndex === true);
const regularPosts = allPosts.filter(p => p.data.isIndex !== true);

const sortedPosts = regularPosts.toSorted((a, b) =>
  new Date(b.data.date) - new Date(a.data.date)
);

const topicMap = new Map();
for (const post of allPosts) {
  for (const topic of post.data.topics || []) {
    topicMap.set(topic, (topicMap.get(topic) || 0) + 1);
  }
}
const topics = Array.from(topicMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 12);

function stripMarkdown(text: string): string {
  if (!text) return '';
  return text
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/\*(.*?)\*/g, '$1')
    .replace(/\[(.*?)\]\(.*?\)/g, '$1')
    .replace(/`(.*?)`/g, '$1')
    .replace(/#{1,6}\s/g, '')
    .replace(/>\s/g, '')
    .replace(/\n/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function getExcerpt(body: string, maxLength = 130) {
  const clean = stripMarkdown(body);
  return clean.length <= maxLength ? clean : clean.slice(0, maxLength) + '…';
}

const searchIndex = allPosts.map(post => ({
  id: post.id,
  title: post.data.title,
  excerpt: getExcerpt(post.data.body || '', 200),
  topics: post.data.topics || [],
}));
---

<Layout title="Home | The Salaf's Path">
  <Hero totalPosts={allPosts.length} totalTopics={topicMap.size} />
  <TopicCloud topics={topics} />

  <!-- Resources / Indexes Section -->
  {indexPosts.length > 0 && (
    <section class="resources-section">
      <div class="container">
        <div class="section-hd">
          <h2 class="section-title">📚 Guides & Resources</h2>
          <span style="font-size:0.8125rem;color:var(--text-light);">
            Curated indexes to help you navigate
          </span>
        </div>
        <div class="resources-grid">
          {indexPosts.map((post) => (
            <a href={`/posts/${post.id}`} class="resource-card">
              <div class="resource-icon">📖</div>
              <h3 class="resource-title">{post.data.title}</h3>
              <p class="resource-desc">
                {post.data.topics && post.data.topics.length > 0
                  ? `Topics: ${post.data.topics.join(', ')}`
                  : 'A curated collection of posts'}
              </p>
              <span class="resource-link">Explore →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Main Posts Section -->
  <div class="posts-section">
    <div class="container">
      <div class="section-hd">
        <h2 class="section-title">Recent Posts</h2>
        <a href="/topics" class="section-link">Browse all →</a>
      </div>

      <div id="search-container" data-index={JSON.stringify(searchIndex)}>
        <div id="search-results" style="display: none;"></div>
      </div>

      <div id="all-posts">
        <div class="posts-grid">
          {sortedPosts.slice(0, 7).map((post) => (
            <PostCard
              id={post.id}
              title={post.data.title}
              date={post.data.date}
              topics={post.data.topics}
              excerpt={getExcerpt(post.data.body || '')}
              featured={post === sortedPosts[0]}
            />
          ))}
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    import Fuse from 'fuse.js';

    (function() {
      const container = document.getElementById('search-container');
      if (!container) return;
      const searchIndex = JSON.parse(container.dataset.index || '[]');

      const searchInput = document.querySelector('.hero-search input');
      if (!searchInput) return;

      let fuse = null;
      let debounceTimer;
      const resultsContainer = document.getElementById('search-results');
      const allPostsContainer = document.getElementById('all-posts');

      function esc(str) {
        if (!str) return '';
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }

      function renderResults(query) {
        const trimmed = query.trim();
        if (!trimmed) {
          allPostsContainer.style.display = 'block';
          resultsContainer.style.display = 'none';
          resultsContainer.innerHTML = '';
          return;
        }

        if (!fuse) {
          fuse = new Fuse(searchIndex, {
            keys: ['title', 'excerpt', 'topics'],
            threshold: 0.3,
          });
        }

        const results = fuse.search(trimmed);
        allPostsContainer.style.display = 'none';
        resultsContainer.style.display = 'block';

        if (results.length === 0) {
          resultsContainer.innerHTML = `<p class="search-empty">No results found for "<strong>${esc(trimmed)}</strong>".</p>`;
          return;
        }

        const grid = document.createElement('div');
        grid.className = 'posts-grid';

        results.forEach(({ item }) => {
          const wrapper = document.createElement('a');
          wrapper.href = `/posts/${item.id}`;
          wrapper.className = 'post-card-link';

          const topicTag = item.topics.length > 0
            ? `<span class="card-topic-tag">${esc(item.topics[0])}</span>`
            : '';

          wrapper.innerHTML = `
            <article class="post-card">
              <div class="card-bar"></div>
              <div class="card-body">
                <div class="card-meta">${topicTag}</div>
                <h3 class="card-title">${esc(item.title)}</h3>
                <p class="card-excerpt">${esc(item.excerpt)}</p>
                <div class="card-footer">
                  <span class="card-cta">Read <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
                </div>
              </div>
            </article>
          `;
          grid.appendChild(wrapper);
        });

        resultsContainer.innerHTML = '';
        resultsContainer.appendChild(grid);
      }

      searchInput.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => renderResults(e.target.value), 200);
      });

      const form = document.querySelector('.hero-search');
      if (form) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          renderResults(searchInput.value);
        });
      }
    })();
  </script>
</Layout>

<style>
  .posts-section { padding: 2.5rem 0 3rem; }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.125rem;
    width: 100%;
  }
  .search-empty, .search-loading {
    text-align: center;
    color: var(--text-light);
    padding: 2rem 0;
    font-size: 1.1rem;
  }
  .post-card-link {
    text-decoration: none;
    display: block;
    max-width: 100%;
  }

  /* Resources Section */
  .resources-section {
    padding: 2.5rem 0 1rem;
    background: var(--light-gold);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.125rem;
  }
  .resource-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-decoration: none;
    transition: transform 0.22s, box-shadow 0.22s, border-color 0.22s;
    display: flex;
    flex-direction: column;
  }
  .resource-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
    border-color: rgba(201,168,76,0.3);
  }
  .resource-icon {
    font-size: 1.625rem;
    margin-bottom: 0.5rem;
  }
  .resource-title {
    font-family: var(--font-title);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.375rem;
    line-height: 1.3;
  }
  .resource-desc {
    font-size: 0.785rem;
    color: var(--text-light);
    line-height: 1.5;
    flex: 1;
    margin-bottom: 0.75rem;
  }
  .resource-link {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    transition: gap 0.18s;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .resource-card:hover .resource-link {
    gap: 0.5rem;
  }

  @media (max-width: 900px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .resources-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
    .resources-grid {
      grid-template-columns: 1fr;
    }
    .post-card.featured .card-title {
      font-size: 1.05rem;
    }
  }
</style>