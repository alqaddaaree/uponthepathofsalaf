---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import TopicCloud from "../components/TopicCloud.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");

// Separate index posts from regular posts
const indexPosts = allPosts.filter((p) => p.data.isIndex === true);
const regularPosts = allPosts.filter((p) => p.data.isIndex !== true);

const sortedPosts = regularPosts.toSorted(
  (a, b) => new Date(b.data.date) - new Date(a.data.date),
);

const topicMap = new Map();
for (const post of allPosts) {
  for (const topic of post.data.topics || []) {
    topicMap.set(topic, (topicMap.get(topic) || 0) + 1);
  }
}
const topics = Array.from(topicMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 12);

function stripMarkdown(text: string): string {
  if (!text) return "";
  return text
    .replace(/\*\*(.*?)\*\*/g, "$1")
    .replace(/\*(.*?)\*/g, "$1")
    .replace(/\[(.*?)\]\(.*?\)/g, "$1")
    .replace(/`(.*?)`/g, "$1")
    .replace(/#{1,6}\s/g, "")
    .replace(/>\s/g, "")
    .replace(/\n/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function getExcerpt(body: string, maxLength = 130) {
  const clean = stripMarkdown(body);
  return clean.length <= maxLength ? clean : clean.slice(0, maxLength) + "…";
}

const searchIndex = allPosts.map((post) => ({
  id: post.id,
  title: post.data.title,
  excerpt: getExcerpt(post.data.body || "", 200),
  topics: post.data.topics || [],
}));
---

<Layout title="Home | The Salaf's Path">
  <Hero totalPosts={allPosts.length} totalTopics={topicMap.size} />
  <TopicCloud topics={topics} />

  <div id="search-container" data-index={JSON.stringify(searchIndex)}></div>

  <!-- Resources / Indexes Section -->
  {
    indexPosts.length > 0 && (
      <section class="resources-section" id="resources-section">
        <div class="container">
          <div class="section-hd">
            <h2 class="section-title">📚 Guides & Resources</h2>
            <span style="font-size:0.8125rem;color:var(--text-light);">
              Curated indexes to help you navigate
            </span>
          </div>
          <div class="resources-grid">
            {indexPosts.map((post) => (
              <a href={`/posts/${post.id}`} class="resource-card">
                <div class="resource-icon">📖</div>
                <h3 class="resource-title">{post.data.title}</h3>
                <p class="resource-desc">
                  {post.data.topics && post.data.topics.length > 0
                    ? `Topics: ${post.data.topics.join(", ")}`
                    : "A curated collection of posts"}
                </p>
                <span class="resource-link">Explore →</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Main Posts Section -->
  <div class="posts-section">
    <div class="container">
      <div class="section-hd">
        <h2 class="section-title">Recent Posts</h2>
        <a href="/topics" class="section-link">Browse all →</a>
      </div>

      <div id="all-posts">
        <div class="posts-grid">
          {
            sortedPosts
              .slice(0, 7)
              .map((post) => (
                <PostCard
                  id={post.id}
                  title={post.data.title}
                  date={post.data.date}
                  topics={post.data.topics}
                  excerpt={getExcerpt(post.data.body || "")}
                  featured={post === sortedPosts[0]}
                />
              ))
          }
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    import Fuse from "fuse.js";

    (function () {
      const container = document.getElementById("search-container");
      if (!container) return;
      const searchIndex = JSON.parse(container.dataset.index || "[]");

      const searchInput = document.querySelector(".hero-search input");
      if (!searchInput) return;

      // Create dropdown and attach to body
      const dropdown = document.createElement("div");
      dropdown.className = "search-dropdown";
      dropdown.hidden = true;
      document.body.appendChild(dropdown);

      let fuse = null;
      let debounceTimer;

      function esc(str) {
        if (!str) return "";
        return str
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      function close() {
        dropdown.innerHTML = "";
        dropdown.hidden = true;
      }

      function positionDropdown() {
        const rect = searchInput.getBoundingClientRect();
        dropdown.style.position = "fixed";
        dropdown.style.top = rect.bottom + 6 + "px";
        dropdown.style.left = rect.left + "px";
        dropdown.style.width = Math.min(rect.width, 600) + "px";
        dropdown.style.maxWidth = "600px";
      }

      function renderResults(query) {
        const trimmed = query.trim();
        if (!trimmed) {
          close();
          return;
        }

        if (!fuse) {
          fuse = new Fuse(searchIndex, {
            keys: [
              { name: "title", weight: 0.7 },
              { name: "topics", weight: 0.2 },
              { name: "excerpt", weight: 0.1 },
            ],
            threshold: 0.3,
            ignoreLocation: true,
            minMatchCharLength: 2,
          });
        }

        const results = fuse.search(trimmed).slice(0, 8);
        dropdown.hidden = false;
        positionDropdown();

        if (results.length === 0) {
          dropdown.innerHTML = `<p class="drop-empty">No results for "<strong>${esc(trimmed)}</strong>"</p>`;
          return;
        }

        dropdown.innerHTML = results
          .map(
            ({ item }) => `
          <a href="/posts/${item.id}" class="drop-item">
            ${item.topics[0] ? `<span class="drop-topic">${esc(item.topics[0])}</span>` : ""}
            <span class="drop-title">${esc(item.title)}</span>
            <span class="drop-excerpt">${esc(item.excerpt)}</span>
          </a>
        `,
          )
          .join("");
      }

      // Event listeners
      searchInput.addEventListener("input", (e) => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => renderResults(e.target.value), 180);
      });

      searchInput.addEventListener("focus", () => {
        if (searchInput.value.trim()) {
          renderResults(searchInput.value);
        }
      });

      // Reposition on scroll/resize to keep dropdown aligned
      window.addEventListener("scroll", () => {
        if (!dropdown.hidden) positionDropdown();
      });
      window.addEventListener("resize", () => {
        if (!dropdown.hidden) positionDropdown();
      });

      // Click outside to close
      document.addEventListener("click", (e) => {
        if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
          close();
        }
      });

      // Escape key to close
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") close();
      });

      // Prevent form submission from reloading
      const form = document.querySelector(".hero-search");
      if (form) {
        form.addEventListener("submit", (e) => {
          e.preventDefault();
          renderResults(searchInput.value);
        });
      }
    })();
  </script>
</Layout>

<style>
  .posts-section {
    padding: 2.5rem 0 3rem;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.125rem;
    width: 100%;
  }
  .post-card-link {
    text-decoration: none;
    display: block;
    max-width: 100%;
  }

  /* ===== DROPDOWN SEARCH STYLES (global) ===== */
  :global(.search-dropdown) {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
    z-index: 9999;
    max-height: 60vh;
    overflow-y: auto;
    min-width: 200px;
    padding: 0.25rem 0;
  }
  :global(.search-dropdown[hidden]) {
    display: none;
  }

  :global(.drop-item) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.6rem 1rem;
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }
  :global(.drop-item:last-child) {
    border-bottom: none;
  }
  :global(.drop-item:hover) {
    background: var(--light-gold);
  }

  :global(.drop-topic) {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
  }
  :global(.drop-title) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary);
    line-height: 1.3;
  }
  :global(.drop-excerpt) {
    font-size: 0.775rem;
    color: var(--text-light);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.drop-empty) {
    padding: 1rem;
    text-align: center;
    color: var(--text-light);
    font-size: 0.875rem;
  }

  /* Resources Section */
  .resources-section {
    padding: 2.5rem 0 1rem;
    background: var(--light-gold);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.125rem;
  }
  .resource-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-decoration: none;
    transition:
      transform 0.22s,
      box-shadow 0.22s,
      border-color 0.22s;
    display: flex;
    flex-direction: column;
  }
  .resource-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
    border-color: rgba(201, 168, 76, 0.3);
  }
  .resource-icon {
    font-size: 1.625rem;
    margin-bottom: 0.5rem;
  }
  .resource-title {
    font-family: var(--font-title);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.375rem;
    line-height: 1.3;
  }
  .resource-desc {
    font-size: 0.785rem;
    color: var(--text-light);
    line-height: 1.5;
    flex: 1;
    margin-bottom: 0.75rem;
  }
  .resource-link {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    transition: gap 0.18s;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .resource-card:hover .resource-link {
    gap: 0.5rem;
  }

  @media (max-width: 900px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .resources-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
    .resources-grid {
      grid-template-columns: 1fr;
    }
    .post-card.featured .card-title {
      font-size: 1.05rem;
    }
  }
</style>
