---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import MarkdownIt from 'markdown-it';

const md = new MarkdownIt({
  html: true,
  linkify: true,
});

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { id: post.id },
  }));
}

const { id } = Astro.params;
const allPosts = await getCollection('posts');
const postEntry = allPosts.find((p) => p.id === id);

if (!postEntry) {
  return Astro.redirect('/');
}

const { data } = postEntry;
const bodyHtml = md.render(data.body || '');

const formattedDate = new Date(data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const relatedPosts = allPosts
  .filter((p) => p.id !== postEntry.id)
  .filter((p) => p.data.topics?.some((t) => data.topics?.includes(t)))
  .sort((a, b) => new Date(b.data.date) - new Date(a.data.date))
  .slice(0, 2);

function stripMarkdown(text: string): string {
  if (!text) return '';
  return text
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/\*(.*?)\*/g, '$1')
    .replace(/\[(.*?)\]\(.*?\)/g, '$1')
    .replace(/`(.*?)`/g, '$1')
    .replace(/#{1,6}\s/g, '')
    .replace(/>\s/g, '')
    .replace(/\n/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function getExcerpt(body: string, maxLength = 130) {
  const clean = stripMarkdown(body);
  if (clean.length <= maxLength) return clean;
  return clean.slice(0, maxLength) + '…';
}
---

<Layout title={`${data.title} | The Salaf's Path`}>
  <article class="post-detail">
    <h1 class="post-main-title">{data.title}</h1>

    <div class="post-meta-bar">
      <div class="meta-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        {formattedDate}
      </div>
    </div>

    <!-- Render body as HTML -->
    <div class="post-body" set:html={bodyHtml} />

    {data.topics && data.topics.length > 0 && (
      <div class="post-tags">
        {data.topics.map((topic: string) => (
          <a href={`/topics/${topic.toLowerCase()}`} class="tag">#{topic}</a>
        ))}
      </div>
    )}

    <div class="ornament">
      <div class="ornament-line"></div>
      <svg width="22" height="22" viewBox="0 0 22 22" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <polygon points="11,1 13.2,7.5 20,7.5 14.4,11.5 16.6,18 11,14 5.4,18 7.6,11.5 2,7.5 8.8,7.5"/>
      </svg>
      <div class="ornament-line"></div>
    </div>

    {relatedPosts.length > 0 && (
      <div class="related-posts">
        <div class="section-hd">
          <h2 class="section-title">Related Posts</h2>
        </div>
        <div class="related-grid">
          {relatedPosts.map((p) => (
            <PostCard
              id={p.id}
              title={p.data.title}
              date={p.data.date}
              author={p.data.author ?? undefined}
              quotedAuthor={p.data.quotedAuthor ?? undefined}
              topics={p.data.topics}
              excerpt={getExcerpt(p.data.body || '')}
            />
          ))}
        </div>
      </div>
    )}

    <div class="post-footer-nav">
      <a href="/" class="back-link">← Back to all posts</a>
    </div>
  </article>
</Layout>

<style>
  /* ⬇️ THIS MUST BE INCLUDED – it styles the post detail page */
  .post-detail {
    max-width: 720px;
    margin: 0 auto;
    padding: 2.5rem 0 4rem;
    width: 100%;
    box-sizing: border-box;
    overflow-x: hidden;
    word-wrap: break-word;
  }
  
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.79rem;
    color: var(--text-light);
    margin-bottom: 2rem;
    font-family: var(--font-english);
    flex-wrap: wrap; /* wrap on small screens */
  }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb span { color: var(--border); }

  .post-topic-pill {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: rgba(201,168,76,0.1);
    padding: 0.28rem 0.7rem;
    border-radius: var(--radius-sm);
    margin-bottom: 1.125rem;
  }
  
  .post-main-title {
    font-family: var(--font-title);
    font-size: clamp(1.45rem, 3vw, 2.1rem);
    font-weight: 700;
    color: var(--primary);
    line-height: 1.3;
    margin-bottom: 1.25rem;
    word-wrap: break-word;
  }
  
  .post-meta-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.25rem;
    padding: 0.9rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.79rem;
    color: var(--text-light);
    font-family: var(--font-english);
    word-wrap: break-word;
  }
  .meta-item svg { color: var(--accent); flex-shrink: 0; }

  .post-body {
    font-size: 0.9875rem;
    line-height: 1.88;
    color: var(--text);
    white-space: pre-wrap;
    word-wrap: break-word;
    overflow-wrap: break-word;
    max-width: 100%;
    overflow-x: auto;
  }
  
  .post-body p, .post-body blockquote, .post-body h1, .post-body h2, .post-body h3, .post-body h4, .post-body li {
    font-family: var(--font-english), var(--font-arabic);
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  
  .post-body p { 
    margin-bottom: 1.25rem; 
    word-wrap: break-word;
  }

  .post-body h1, .post-body h2, .post-body h3, .post-body h4 {
    font-family: var(--font-title);
    color: var(--primary);
    margin: 2rem 0 0.75rem;
    word-wrap: break-word;
  }

  .post-body blockquote {
    border-left: 4px solid var(--accent);
    background: var(--light-gold);
    padding: 1.25rem 1.5rem;
    margin: 1.75rem 0;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  .post-body blockquote p { margin-bottom: 0.5rem; font-style: italic; color: #3a3528; }
  .post-body blockquote cite {
    font-size: 0.79rem;
    color: var(--text-light);
    font-style: normal;
    font-weight: 600;
  }

  .post-body blockquote[dir="rtl"] {
    border-left: none;
    border-right: 4px solid var(--accent);
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
  }

  /* Code blocks and long pre elements */
  .post-body pre,
  .post-body code {
    max-width: 100%;
    overflow-x: auto;
    white-space: pre-wrap;
    word-wrap: break-word;
    font-family: var(--font-code);
  }

  /* Ensure images don't overflow */
  .post-body img {
    max-width: 100%;
    height: auto;
  }

  /* Lists */
  .post-body ul,
  .post-body ol {
    padding-left: 1.5rem;
    margin: 0.75rem 0 1.25rem;
    list-style-position: inside;
    word-wrap: break-word;
  }

  .post-body li {
    margin-bottom: 0.3rem;
    line-height: 1.7;
    word-wrap: break-word;
  }

  .post-body li p {
    margin: 0;
    display: inline;
  }

  .post-tags { 
    display: flex; 
    gap: 0.4rem; 
    flex-wrap: wrap; 
    margin: 2rem 0; 
  }
  .tag {
    font-size: 0.72rem;
    padding: 0.22rem 0.6rem;
    background: var(--light-gold);
    border: 1px solid rgba(201,168,76,0.28);
    border-radius: var(--radius-sm);
    color: var(--text-light);
    transition: all 0.18s;
    word-wrap: break-word;
  }
  .tag:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

  .related-posts { 
    padding-top: 2rem; 
    border-top: 1px solid var(--border); 
  }
  .related-grid { 
    display: grid; 
    grid-template-columns: repeat(2, 1fr); 
    gap: 1rem; 
  }

  .post-footer-nav { margin-top: 2.5rem; }
  .back-link {
    color: var(--text-light);
    font-size: 0.9rem;
    transition: color 0.15s;
    font-family: var(--font-english);
  }
  .back-link:hover { color: var(--primary); }

  /* Responsive */
  @media (max-width: 768px) {
    .post-detail { 
      padding: 1.5rem 1rem; 
    }
    .related-grid { 
      grid-template-columns: 1fr; 
    }
    .post-meta-bar { 
      gap: 0.75rem; 
    }
    .post-body blockquote { 
      padding: 0.8rem 1rem; 
    }
    .post-body ul,
    .post-body ol {
      padding-left: 1rem;
    }
  }
  @media (max-width: 480px) {
    .post-body blockquote { 
      padding: 0.6rem 0.8rem; 
      margin: 1rem 0;
    }
    .post-body {
      font-size: 0.9rem;
    }
    .post-main-title {
      font-size: 1.2rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.post-body p, .post-body blockquote, .post-body h1, .post-body h2, .post-body h3, .post-body h4, .post-body li')
    .forEach(el => el.dir = 'auto');
</script>