---
// src/pages/posts/[...slug].astro
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: String(post.data.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} | The Salaf's Path`}>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      
      <div class="post-meta">
        <time datetime={post.data.date}>
          {new Date(post.data.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
        {post.data.author && (
          <span class="post-author"> · {post.data.author}</span>
        )}
        {post.data.quotedAuthor && (
          <span class="post-quoted"> · {post.data.quotedAuthor}</span>
        )}
        {post.data.edited && (
          <span class="post-edited"> · Edited</span>
        )}
      </div>

      {post.data.topics && post.data.topics.length > 0 && (
        <div class="post-topics">
          {post.data.topics.map((topic) => (
            <a href={`/topics/${topic.toLowerCase()}`} class="topic-tag">
              {topic}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="post-body">
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/" class="back-link">← Back to all posts</a>
    </footer>
  </article>

  <style>
    .post {
      background: white;
      padding: 2.5rem 3rem;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    }

    .post-header {
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 2px solid var(--gold-light);
    }

    .post-title {
      font-family: var(--font-serif);
      font-size: 2rem;
      color: var(--primary);
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }

    .post-meta {
      font-size: 0.85rem;
      color: var(--text-light);
    }

    .post-edited {
      font-style: italic;
      font-size: 0.8rem;
    }

    .post-topics {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.8rem;
    }

    .topic-tag {
      background: var(--gold-light);
      color: var(--primary);
      padding: 0.2rem 0.9rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .topic-tag:hover {
      background: var(--gold);
      color: white;
    }

    .post-body {
      font-family: var(--font-serif);
      font-size: 1.1rem;
      line-height: 1.9;
      color: var(--text);
    }

    .post-body h1, 
    .post-body h2, 
    .post-body h3,
    .post-body h4 {
      font-family: var(--font-serif);
      color: var(--primary);
      margin: 1.5rem 0 0.8rem 0;
    }

    .post-body blockquote {
      border-left: 4px solid var(--gold);
      padding: 0.8rem 1.5rem;
      margin: 1.2rem 0;
      background: #faf8f4;
      border-radius: 0 4px 4px 0;
      font-style: italic;
    }

    .post-body blockquote p {
      margin: 0;
    }

    .post-body ul,
    .post-body ol {
      padding-left: 1.5rem;
      margin: 0.8rem 0;
    }

    .post-body li {
      margin-bottom: 0.3rem;
    }

    .post-body strong {
      color: var(--primary);
    }

    .post-body a {
      color: var(--primary-light);
      text-decoration: underline;
    }

    .post-body a:hover {
      color: var(--primary);
    }

    .post-footer {
      margin-top: 2.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }

    .back-link {
      color: var(--text-light);
      text-decoration: none;
      font-size: 0.9rem;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: var(--primary);
    }

    @media (max-width: 600px) {
      .post {
        padding: 1.5rem;
      }

      .post-title {
        font-size: 1.5rem;
      }

      .post-body {
        font-size: 1rem;
      }
    }
  </style>
</Layout>