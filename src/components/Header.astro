---
// src/components/Header.astro
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path;
---

<header class="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="site-logo">
      <svg class="logo-mark" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="19" cy="19" r="18" fill="#F0E6D3" stroke="#C9A84C" stroke-width="1"/>
        <polygon points="19,4 21.6,12.4 30.4,10.2 25.5,17.4 33.5,21 25.5,24.6 30.4,31.8 21.6,29.6 19,38 16.4,29.6 7.6,31.8 12.5,24.6 4.5,21 12.5,17.4 7.6,10.2 16.4,12.4"
                 fill="#1B4332" opacity="0.85"/>
        <circle cx="19" cy="21" r="4.5" fill="#C9A84C"/>
      </svg>
      <div class="logo-text">
        <span class="logo-en">The Salaf's Path</span>
        <span class="logo-ar">درب السلف</span>
      </div>
    </a>

    <!-- Navigation -->
    <nav class="header-nav">
      <a href="/" class={`nav-link ${isActive('/') ? 'active' : ''}`}>Home</a>
      <a href="/topics" class={`nav-link ${isActive('/topics') ? 'active' : ''}`}>Topics</a>
      <a href="/about" class={`nav-link ${isActive('/about') ? 'active' : ''}`}>About</a>
      <button class="nav-search-btn" aria-label="Search">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
    </nav>
  </div>
</header>

<style>
  .site-header {
    height: var(--header-h);
    background: var(--card-bg);
    border-bottom: 2.5px solid var(--accent);
    position: sticky;
    top: 0;
    z-index: 900;
    box-shadow: 0 1px 8px rgba(27,67,50,0.07);
  }
  .header-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
    cursor: pointer;
  }
  .logo-mark { width: 38px; height: 38px; flex-shrink: 0; }
  .logo-text { display: flex; flex-direction: column; line-height: 1.2; }
  .logo-en {
    font-family: var(--font-ar);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--primary);
    letter-spacing: 0.01em;
  }
  .logo-ar {
    font-family: var(--font-ar);
    font-size: 0.85rem;
    color: var(--accent);
    direction: rtl;
  }
  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    margin-left: auto;
  }
  .nav-link {
    font-size: 0.8375rem;
    font-weight: 500;
    color: var(--text-light);
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--primary);
    background: var(--light-gold);
  }
  .nav-search-btn {
    padding: 0.4rem 0.5rem;
    color: var(--text-light);
    border: none;
    background: transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    display: flex;
    align-items: center;
  }
  .nav-search-btn:hover { color: var(--primary); background: var(--light-gold); }

  @media (max-width: 768px) {
    .logo-ar { display: none; }
    .nav-link { padding: 0.375rem 0.5rem; font-size: 0.78rem; }
    .header-inner { gap: 1rem; }
  }
  @media (max-width: 480px) {
    .logo-en { font-size: 0.9rem; }
    .logo-mark { width: 30px; height: 30px; }
  }
</style>
