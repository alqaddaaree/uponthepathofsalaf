---
// src/components/PostCard.astro
import { renderCardHTML } from '../utils/renderCard';

export interface Props {
  id: number;
  title: string;
  date: string;
  author?: string | null;
  quotedAuthor?: string | null;
  topics?: string[];
  excerpt?: string;
  featured?: boolean;
}

const { id, title, date, author, quotedAuthor, topics = [], excerpt, featured = false } = Astro.props;

// Format date for display
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const displayAuthor = quotedAuthor || author;

const cardData = {
  id,
  title,
  excerpt: excerpt || '',
  topics,
  author: displayAuthor || undefined,
  date: formattedDate,
  featured,
  url: `/posts/${id}`,
};
---

<a href={`/posts/${id}`} class="post-card-link">
  <Fragment set:html={renderCardHTML(cardData)} />
</a>