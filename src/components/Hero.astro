---
// src/components/Hero.astro
export interface Props {
  totalPosts?: number;
  totalTopics?: number;
  totalScholars?: number;
}

const { totalPosts = 1500, totalTopics = 12, totalScholars = 60 } = Astro.props;
---

<div class="hero">
  <!-- Geometric Pattern Background -->
  <svg class="hero-geo" viewBox="0 0 1200 480" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id="star-tile" x="0" y="0" width="90" height="90" patternUnits="userSpaceOnUse">
        <polygon points="45,3 48.5,17 62,12 55,25 68,31 54,34 56,50 45,41 34,50 36,34 22,31 35,25 28,12 41.5,17"
                 fill="none" stroke="rgba(201,168,76,0.14)" stroke-width="0.9"/>
        <line x1="45" y1="22" x2="45" y2="28" stroke="rgba(255,255,255,0.06)" stroke-width="0.5"/>
        <line x1="42" y1="25" x2="48" y2="25" stroke="rgba(255,255,255,0.06)" stroke-width="0.5"/>
        <circle cx="0"  cy="0"  r="1.2" fill="rgba(255,255,255,0.05)"/>
        <circle cx="90" cy="0"  r="1.2" fill="rgba(255,255,255,0.05)"/>
        <circle cx="0"  cy="90" r="1.2" fill="rgba(255,255,255,0.05)"/>
        <circle cx="90" cy="90" r="1.2" fill="rgba(255,255,255,0.05)"/>
        <circle cx="45" cy="45" r="1"   fill="rgba(201,168,76,0.08)"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#star-tile)"/>
  </svg>

  <!-- Decorative medallions -->
  <svg class="hero-medallion hero-medallion-br" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
    <polygon points="100,8 110,42 144,28 128,60 164,68 138,92 152,126 118,116 108,150 88,116 54,126 68,92 42,68 78,60 62,28 96,42" fill="#C9A84C"/>
    <circle cx="100" cy="100" r="28" fill="none" stroke="#C9A84C" stroke-width="2"/>
  </svg>
  <svg class="hero-medallion hero-medallion-tl" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
    <polygon points="100,8 110,42 144,28 128,60 164,68 138,92 152,126 118,116 108,150 88,116 54,126 68,92 42,68 78,60 62,28 96,42" fill="#ffffff"/>
  </svg>

  <div class="hero-content">
    <div class="hero-bismillah">بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ</div>
    <h1 class="hero-title">Upong The Path Of The Salaf</h1>
    <div class="hero-subtitle-ar">عَلَى نَهْجِ السَّلَفِ</div>
    <p class="hero-tagline">
      A curated library of Islamic knowledge from the Quran, Sunnah, and the scholars
      of Ahl al-Sunnah — for every seeker of sacred knowledge.
    </p>

    <div class="hero-search">
      <input type="text" placeholder="Search posts, scholars, topics…" id="hero-search-input">
      <button class="hero-search-btn" aria-label="Search">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
    </div>

    <div class="hero-stats">
      <div class="hero-stat">
        <span class="hero-stat-num">{totalPosts}+</span>
        <span class="hero-stat-lbl">Posts</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-num">{totalTopics}</span>
        <span class="hero-stat-lbl">Topics</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-num">{totalScholars}+</span>
        <span class="hero-stat-lbl">Scholars</span>
      </div>
    </div>
  </div>
</div>

<style>
  .hero {
    background: linear-gradient(150deg, #162f25 0%, var(--primary) 45%, var(--secondary) 100%);
    position: relative;
    overflow: hidden;
    padding: 4.5rem 1.5rem 4rem;
    text-align: center;
  }
  .hero-geo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .hero-medallion {
    position: absolute;
    pointer-events: none;
    opacity: 0.06;
    width: 340px;
    height: 340px;
  }
  .hero-medallion-br { bottom: -60px; right: -60px; }
  .hero-medallion-tl { top: -60px; left: -60px; width: 280px; height: 280px; opacity: 0.05; }

  .hero-content { position: relative; }
  .hero-bismillah {
    font-family: var(--font-ar);
    font-size: 1.4rem;
    color: rgba(201,168,76,0.65);
    direction: rtl;
    margin-bottom: 1.375rem;
  }
  .hero-title {
    font-family: var(--font-title);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 0.375rem;
  }
  .hero-subtitle-ar {
    font-family: var(--font-ar);
    font-size: 1.375rem;
    color: var(--accent);
    direction: rtl;
    margin-bottom: 1.125rem;
  }
  .hero-tagline {
    font-size: 0.9375rem;
    font-weight: 300;
    color: rgba(255,255,255,0.72);
    max-width: 490px;
    margin: 0 auto 2.25rem;
    line-height: 1.75;
  }
  .hero-search {
    max-width: 460px;
    margin: 0 auto 2.25rem;
    position: relative;
  }
  .hero-search input {
    width: 100%;
    padding: 0.8rem 3.25rem 0.8rem 1.25rem;
    background: rgba(255,255,255,0.96);
    border: 2px solid transparent;
    border-radius: 50px;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .hero-search input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 4px rgba(201,168,76,0.22);
  }
  .hero-search input::placeholder { color: var(--text-light); }
  .hero-search-btn {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    background: var(--accent);
    border: none;
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .hero-search-btn:hover { background: var(--accent-dark); }
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 2.75rem;
  }
  .hero-stat { text-align: center; color: rgba(255,255,255,0.8); }
  .hero-stat-num {
    display: block;
    font-family: var(--font-ar);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
  }
  .hero-stat-lbl {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    opacity: 0.65;
  }

  @media (max-width: 768px) {
    .hero-stats { gap: 1.75rem; }
    .hero-medallion { display: none; }
  }
  @media (max-width: 480px) {
    .hero-bismillah { font-size: 1.1rem; }
    .hero-search input { font-size: 0.8rem; padding: 0.7rem 3rem 0.7rem 1rem; }
  }
</style>
